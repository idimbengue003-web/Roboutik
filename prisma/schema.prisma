// Schema for Roblox kids marketplace with Wave payment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Use a dedicated schema to avoid collisions with other projects sharing the same Neon DB
  schemas  = ["roboutik"]
}

// All models live in the "roboutik" schema (separate from "public")
// Prisma creates this schema automatically on first db push

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  username   String
  avatar     String?
  googleSub  String?  @unique
  isSeller   Boolean  @default(false)
  balance    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listings       Listing[]     @relation("SellerListings")
  buyerOrders    Order[]       @relation("BuyerOrders")
  sellerOrders   Order[]       @relation("SellerOrders")
  messages       Message[]
  ratingsGiven   Rating[]      @relation("RatingFrom")
  ratingsReceived Rating[]     @relation("RatingTo")
  withdrawals    Withdrawal[]

  @@schema("roboutik")
}

model Game {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  image       String
  description String
  isFavorite  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  listings Listing[]

  @@schema("roboutik")
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("SellerListings", fields: [sellerId], references: [id])
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id])
  title       String
  description String
  price       Int
  image       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  orders  Order[]
  ratings Rating[]

  @@schema("roboutik")
}

model Order {
  id             String    @id @default(cuid())
  listingId      String
  listing        Listing   @relation(fields: [listingId], references: [id])
  buyerId        String
  buyer          User      @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId       String
  seller         User      @relation("SellerOrders", fields: [sellerId], references: [id])
  amount         Int
  status         String    @default("PENDING_PAYMENT")
  paidAt         DateTime?
  deliveredAt    DateTime?
  autoValidateAt DateTime?
  validatedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages Message[]
  rating   Rating?

  @@schema("roboutik")
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  isAuto    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@schema("roboutik")
}

model Rating {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  fromUserId String
  fromUser   User     @relation("RatingFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingTo", fields: [toUserId], references: [id])
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@schema("roboutik")
}

model Withdrawal {
  id         String   @id @default(cuid())
  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  amount     Int
  waveNumber String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("roboutik")
}
