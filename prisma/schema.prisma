// Schema for Roblox kids marketplace with Wave payment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Use a dedicated schema to avoid collisions with other projects sharing the same Neon DB
  schemas  = ["roboutik"]
}

// All models live in the "roboutik" schema (separate from "public")
// Prisma creates this schema automatically on first db push

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  username   String
  avatar     String?
  googleSub  String?  @unique
  isSeller   Boolean  @default(false)
  isAdmin    Boolean  @default(false)
  isBanned   Boolean  @default(false)
  bannedAt   DateTime?
  banReason  String?
  balance    Int      @default(0)
  // 2FA: 6-digit code emailed to admin for sensitive actions (ban, withdrawals)
  twoFactorCode           String?
  twoFactorCodeExpiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listings       Listing[]     @relation("SellerListings")
  buyerOrders    Order[]       @relation("BuyerOrders")
  sellerOrders   Order[]       @relation("SellerOrders")
  messages       Message[]
  ratingsGiven   Rating[]      @relation("RatingFrom")
  ratingsReceived Rating[]     @relation("RatingTo")
  withdrawals    Withdrawal[]
  ticketsOpened  SupportTicket[] @relation("TicketOpener")
  ticketMessages TicketMessage[]
  auditLogsActor AuditLog[]    @relation("AuditActor")
  auditLogsTarget AuditLog[]   @relation("AuditTarget")
  convsAsBuyer   Conversation[] @relation("ConvBuyer")
  convsAsSeller  Conversation[] @relation("ConvSeller")
  convMessages   ConversationMessage[]

  @@schema("roboutik")
}

model Game {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  image       String
  description String
  isFavorite  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  listings Listing[]

  @@schema("roboutik")
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("SellerListings", fields: [sellerId], references: [id])
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id])
  title       String
  description String
  price       Int // price displayed to buyer (includes 20% commission)
  sellerNetPrice Int // amount the seller actually receives after commission
  image       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  orders  Order[]
  ratings Rating[]
  conversations Conversation[]

  @@schema("roboutik")
}

model Order {
  id             String    @id @default(cuid())
  listingId      String
  listing        Listing   @relation(fields: [listingId], references: [id])
  buyerId        String
  buyer          User      @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId       String
  seller         User      @relation("SellerOrders", fields: [sellerId], references: [id])
  amount         Int // total amount paid by buyer (incl. commission)
  sellerNetAmount Int // net amount the seller receives (excl. commission), frozen at order time
  status         String    @default("PENDING_PAYMENT")
  paidAt         DateTime?
  deliveredAt    DateTime?
  autoValidateAt DateTime?
  validatedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages Message[]
  rating   Rating?

  @@schema("roboutik")
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  isAuto    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@schema("roboutik")
}

model Rating {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  fromUserId String
  fromUser   User     @relation("RatingFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingTo", fields: [toUserId], references: [id])
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@schema("roboutik")
}

model Withdrawal {
  id         String   @id @default(cuid())
  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  amount     Int
  waveNumber String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("roboutik")
}

model SupportTicket {
  id          String   @id @default(cuid())
  openerId    String
  opener      User     @relation("TicketOpener", fields: [openerId], references: [id])
  subject     String
  category    String   @default("OTHER") // PAYMENT, DELIVERY, SELLER, BUG, ACCOUNT, OTHER
  status      String   @default("OPEN") // OPEN, BOT_HANDLED, ADMIN_HANDLED, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  // Snapshot of the orderId if the ticket is about a specific order
  orderId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    TicketMessage[]

  @@schema("roboutik")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String?
  sender     User?    @relation(fields: [senderId], references: [id])
  // senderRole: USER (ticket opener), BOT (auto-response), ADMIN (human support)
  senderRole String   @default("USER")
  content    String
  isAuto     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@schema("roboutik")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  targetId   String?
  target     User?    @relation("AuditTarget", fields: [targetId], references: [id])
  action     String   // BAN_USER, UNBAN_USER, VALIDATE_WITHDRAWAL, REJECT_WITHDRAWAL, DELETE_LISTING, etc.
  metadata   String?  // JSON string with extra context
  createdAt  DateTime @default(now())

  @@schema("roboutik")
}

// Pre-sale conversation between a buyer and a seller about a specific listing
model Conversation {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User     @relation("ConvBuyer", fields: [buyerId], references: [id])
  sellerId    String
  seller      User     @relation("ConvSeller", fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ConversationMessage[]

  @@unique([listingId, buyerId])
  @@schema("roboutik")
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  content        String
  isAuto         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@schema("roboutik")
}

// Log of notifications sent (avoid double-sending, audit trail)
model NotificationLog {
  id         String   @id @default(cuid())
  // CHANNEL: EMAIL | WHATSAPP
  channel    String
  // TYPE: NEW_MESSAGE | NEW_ORDER | ORDER_VALIDATED | WITHDRAWAL_STATUS | TICKET_REPLY
  type       String
  recipientUserId String
  recipientEmail  String?
  recipientPhone  String?
  subject    String?
  body       String
  // STATUS: PENDING | SENT | FAILED | SKIPPED (no API key)
  status     String   @default("PENDING")
  errorMessage String?
  // Optional reference to related entity
  refType    String?  // CONVERSATION_MESSAGE | ORDER | TICKET | WITHDRAWAL
  refId      String?
  createdAt  DateTime @default(now())

  @@index([recipientUserId, createdAt])
  @@schema("roboutik")
}

// Self-hosted error tracking (Sentry-like)
model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  stack      String?
  severity   String   @default("medium") // low | medium | high | critical
  userId     String?
  path       String?
  method     String?
  userAgent  String?
  metadata   String?  // JSON
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([severity, createdAt])
  @@index([resolved, createdAt])
  @@schema("roboutik")
}
