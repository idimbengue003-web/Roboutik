# Development local
# Pour le dev local, tu peux utiliser soit SQLite (provider="sqlite" dans schema.prisma)
# soit une base PostgreSQL Neon locale/distante.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Pour Vercel, configure DATABASE_URL dans Project Settings > Environment Variables
# avec l'URL de connexion Neon (visible dans le dashboard Neon).
