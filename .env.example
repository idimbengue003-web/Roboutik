# ============================================================
# Roboutik - Environment Variables
# ============================================================
# Copy this file to .env (local dev) or set them in Vercel Project Settings.

# ---------- Database (Neon PostgreSQL) ----------
# Get this from Neon dashboard: https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- NextAuth (REQUIRED for Google OAuth) ----------
# Generate a random 32+ char secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-secret-string"
# Public URL of the app
# Local dev:  http://localhost:3000
# Production: https://roboutik.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---------- Google OAuth (REQUIRED for Google sign-in) ----------
# Get these from Google Cloud Console:
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create Credentials → OAuth client ID → Application type: Web application
# 3. Authorized JavaScript origins:
#      http://localhost:3000
#      https://roboutik.vercel.app
# 4. Authorized redirect URIs:
#      http://localhost:3000/api/auth/callback/google
#      https://roboutik.vercel.app/api/auth/callback/google
# 5. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---------- Email notifications (Resend, OPTIONAL) ----------
# Get from https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Roboutik <notifications@roboutik.sn>"

# ---------- WhatsApp notifications (Twilio, OPTIONAL) ----------
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ---------- Wave Business Checkout (PUBLIC, used by buyers) ----------
# Your Wave Business payment link. MUST accept ?amount=MONTANT in FCFA.
# Find it in Wave Business dashboard → Payment links.
WAVE_CHECKOUT_BASE_URL="https://pay.wave.com/m/M_REPLACE_WITH_YOUR_BUSINESS_ID"

# ---------- Wave Business Scraper (PRIVATE, used to confirm payments) ----------
# These allow the backend to scrape Wave Business GraphQL for incoming
# payments and confirm orders in < 10s.
#
# HOW TO GET THESE:
# 1. Connecte-toi à https://business.wave.com
# 2. Ouvre DevTools (F12) → onglet Network → filtre "graphql"
# 3. Effectue une action (ex: rafraîchir les transactions)
# 4. Clique sur la requête graphql → onglet Headers
#    → URL: copie l'URL (WAVE_BUSINESS_GRAPHQL_URL)
#    → Cookie: copie la valeur du cookie "session" (WAVE_BUSINESS_SESSION)
# 5. Dans l'URL du dashboard (https://business.wave.com/accounts/XXX/...),
#    récupère l'account_id (WAVE_BUSINESS_ACCOUNT_ID)
WAVE_BUSINESS_GRAPHQL_URL="https://business.wave.com/graphql"
WAVE_BUSINESS_SESSION=""
WAVE_BUSINESS_ACCOUNT_ID=""
